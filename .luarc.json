{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime.version": "Lua 5.1",
  "runtime.nonstandardSymbol": [
    "!=",
    "continue",
    "//"
  ],
  "workspace.ignoreDir": [
    "libs",
    ".libraries",
    ".git",
    ".vscode",
    ".claude"
  ],
  "diagnostics.workspaceDelay": 3000,
  "diagnostics.disable": [
    "lowercase-global",
    "duplicate-set-field",
    "missing-fields",
    "inject-field",
    "cast-local-type",
    "param-type-mismatch",
    "return-type-mismatch"
  ],
  "diagnostics.globals": [
    "AceGUIWidgetLSMlists",
    "BattlegroundWinConditionsDB",
    "C_ChatInfo",
    "C_PvP",
    "C_Timer",
    "C_UIWidgetManager",
    "CopyTable",
    "CreateFrame",
    "Enum",
    "FACTION_ALLIANCE",
    "FACTION_HORDE",
    "FrameUtil",
    "GetClassColor",
    "GetInstanceInfo",
    "GetNumGroupMembers",
    "GetPlayerFactionGroup",
    "GetRealmName",
    "GetTime",
    "HOURS_MINUTES_SECONDS",
    "IsInGroup",
    "IsInGuild",
    "IsInInstance",
    "IsInRaid",
    "LE_PARTY_CATEGORY_HOME",
    "LE_PARTY_CATEGORY_INSTANCE",
    "LibStub",
    "MINUTES_SECONDS",
    "SECONDS_PER_DAY",
    "SECONDS_PER_HOUR",
    "SECONDS_PER_MIN",
    "SLASH_BGWC1",
    "SLASH_BGWC2",
    "SLASH_BGWC3",
    "SlashCmdList",
    "UIParent",
    "UnitClass",
    "UnitExists",
    "UnitName",
    "format",
    "issecretvalue",
    "strsplit",
    "time",
    "wipe"
  ],
  "completion.callSnippet": "Replace",
  "completion.keywordSnippet": "Replace",
  "hint.enable": true,
  "hint.setType": true,
  "semantic.enable": true,
  "telemetry.enable": false
}
